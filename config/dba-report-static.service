[Unit]
Description=DBA Portal static report exports
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=semaphore
Group=semaphore
WorkingDirectory=/dbaportal/exports
ExecStart=/usr/bin/python3 -m http.server 8080 --bind 0.0.0.0
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadOnlyPaths=/dbaportal/exports

[Install]
WantedBy=multi-user.target
